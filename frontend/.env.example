# EmailJS (server-side only — DO NOT prefix with NEXT_PUBLIC_)
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Upstash Redis (auto-injected by Vercel when you provision the integration)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Analytics (auto-injected by Vercel, no config needed)
